/* Adhbhut Lock Screen Theme */

#lockDialogGroup {
    background: rgba(25, 25, 35, 0.9);
    background-image: url("/home/addy/projects/scripts/conf/wallpapers/grey-yellow.png");
    background-size: cover;
    background-position: center;
}

.unlock-dialog {
    background: rgba(20, 20, 30, 0.95);
    border: 1px solid #E67CA0;
    border-radius: 12px;
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
}

.unlock-dialog .button {
    background: rgba(30, 30, 45, 0.9);
    color: #E67CA0;
    border: 1px solid #E67CA0;
    border-radius: 6px;
}

.unlock-dialog .button:focus,
.unlock-dialog .button:hover {
    background: #E67CA0;
    color: #ffffff;
}

.login-dialog {
    background: rgba(20, 20, 30, 0.95);
}

.user-widget-label {
    color: #E67CA0;
}

.password-entry {
    background: rgba(30, 30, 45, 0.9);
    color: #E67CA0;
    border: 1px solid #E67CA0;
    border-radius: 6px;
}

.password-entry:focus {
    border-color: #E67CA0;
    box-shadow: 0 0 8px #E67CA0;
}

/* Clock and date */
.clock-time {
    color: #E67CA0;
    font-size: 48pt;
}

.clock-date {
    color: #E67CA0;
    font-size: 14pt;
}

/* System menu */
.popup-menu {
    background: rgba(20, 20, 30, 0.95);
    color: #E67CA0;
    border: 1px solid #E67CA0;
}

/* Power button */
.power-icon {
    color: #E67CA0;
}

.power-icon:hover {
    color: #ffffff;
    background: #E67CA0;
}
